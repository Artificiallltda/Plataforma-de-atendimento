# Supabase (frontend usa anon key — NUNCA service_role aqui)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL da API (backend Fastify) — usado para disparar feedback-trigger
# e qualquer outra rota REST do backend.
NEXT_PUBLIC_API_URL=https://plataforma-de-atendimento-production.up.railway.app

# Token do bot (usado em SSR para configurar webhook se necessário)
TELEGRAM_BOT_TOKEN=
