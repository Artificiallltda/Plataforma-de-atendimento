# Supabase (frontend usa anon key — NUNCA service_role aqui)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL da API (backend Fastify) — usado para disparar feedback-trigger
# e qualquer outra rota REST do backend.
NEXT_PUBLIC_API_URL=https://plataforma-de-atendimento-production.up.railway.app

# Token do bot (usado em SSR para configurar webhook se necessário)
TELEGRAM_BOT_TOKEN=

# URL interna do backend Fastify (server-side only)
BACKEND_URL=https://plataforma-de-atendimento-production.up.railway.app

# Bearer token do admin — server-side only. MESMO valor que ADMIN_API_TOKEN
# do backend. Não expor com prefixo NEXT_PUBLIC_.
ADMIN_API_TOKEN=
