# WhatsApp Cloud API
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=paa_whatsapp_verify_2026
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_URL=https://paa-api.railway.app/webhooks/whatsapp

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google AI (Gemini) - Modelos Atualizados 2026
# Aceita GEMINI_API_KEY (canônico) ou GOOGLE_AI_API_KEY (legacy).
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
GEMINI_MODEL_ROUTER=gemini-2.5-flash
GEMINI_MODEL_ROUTER_FALLBACK=gemini-3.1-flash-lite-preview
GEMINI_MODEL_SUPPORT=gemini-3.1-pro
GEMINI_MODEL_FINANCE=gemini-2.5-flash
GEMINI_MODEL_SALES=gemini-3.1-pro

# Vertex AI (preferido em produção — sem rate limits agressivos)
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=

# Handoff Notification (Slack incoming webhook — avisa atendentes humanos)
SLACK_WEBHOOK_URL=

# Dashboard frontend (usado em links de handoff)
FRONTEND_URL=https://plataforma-de-atendimento-production.up.railway.app

# Redis
REDIS_URL=redis://localhost:6379

# Telegram (reutilizar ChefIA)
TELEGRAM_BOT_TOKEN=

# Integrações
GURU_API_KEY=
ASAAS_API_KEY=
